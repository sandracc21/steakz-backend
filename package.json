{
  "name": "steakz-mis-backend",
  "version": "1.0.0",
  "description": "REST API for Steakz multi-branch MIS with strict branch isolation.",
  "main": "dist/server.js",
  "scripts": {
    "predev": "kill-port 4000 || true",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node --files src/server.ts\"",
    "build": "echo 'No build needed'",
    "start": "./node_modules/.bin/ts-node --files src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node --files prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --files prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/node": "^20.19.42",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.9"
  }
}