generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  Pending
  Preparing
  Served
  Paid
}

enum InventoryStatus {
  Normal
  LowStock
}

enum FulfillmentType {
  Collection
  Delivery
}

enum ReservationStatus {
  Pending
  Seated
  Cancelled
}

model Branch {
  id             String          @id @default(uuid())
  name           String          @unique
  location       String
  users          User[]
  orders         Order[]
  inventoryItems InventoryItem[]
  menuItems      MenuItem[]
  shifts         Shift[]
  reservations   Reservation[]
  reviews        Review[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Int
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  shifts    Shift[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
}

model Order {
  id              String           @id @default(uuid())
  tableNumber     Int
  items           Json
  totalAmount     Decimal          @db.Decimal(10, 2)
  status          OrderStatus      @default(Pending)
  customerName    String?
  customerPhone   String?
  fulfillmentType FulfillmentType?
  notes           String?
  orderSource     String           @default("Staff")
  branchId        String
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([branchId])
  @@index([status])
  @@index([fulfillmentType])
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  available   Boolean  @default(true)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId])
  @@index([available])
}

model InventoryItem {
  id        String          @id @default(uuid())
  itemName  String
  quantity  Int
  status    InventoryStatus @default(Normal)
  branchId  String
  branch    Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([branchId])
}

model Shift {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([userId])
}

model Reservation {
  id            String            @id @default(uuid())
  customerName  String
  customerEmail String?
  partySize     Int
  tableNumber   Int
  date          DateTime
  notes         String?
  items         Json
  totalAmount   Decimal           @db.Decimal(10, 2)
  status        ReservationStatus @default(Pending)
  branchId      String
  branch        Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([branchId])
  @@index([status])
}

model Review {
  id           String   @id @default(uuid())
  orderId      String   @unique
  customerName String
  rating       Int
  comment      String?
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())

  @@index([branchId])
  @@index([rating])
}
